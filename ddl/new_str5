INSERT INTO genres (genre_name)
SELECT DISTINCT BTRIM(token)
FROM raw_anime
CROSS JOIN LATERAL regexp_split_to_table(COALESCE(genre, ''), ',') AS token
WHERE BTRIM(token) <> ''
ON CONFLICT (genre_name) DO NOTHING;

