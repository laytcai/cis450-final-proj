# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit credentials.

# PostgreSQL connection (AWS RDS)
PGHOST=your-rds-endpoint.region.rds.amazonaws.com
PGPORT=5432
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGDATABASE=anime_analytics

# Set to `disable` to turn off SSL (not recommended for RDS)
PGSSL=require

# Server
PORT=8080
NODE_ENV=development

# Comma-separated list of allowed CORS origins (frontend dev + prod URLs)
CORS_ORIGINS=http://localhost:5173
